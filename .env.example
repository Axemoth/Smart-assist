# Database (use SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./todo.db
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth Secrets (change these in production!)
ACCESS_SECRET_KEY=supersecretaccesskeychangeinprod123!
REFRESH_SECRET_KEY=supersecretrefreshkeychangeinprod123!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (use localhost for local dev, Upstash URL for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# Email (Resend SMTP)
MAIL_USERNAME=resend
MAIL_PASSWORD=re_your_resend_api_key
MAIL_FROM=noreply@yourdomain.com
MAIL_PORT=465
MAIL_SERVER=smtp.resend.com
MAIL_FROM_NAME="Smart Assist"
MAIL_STARTTLS=False
MAIL_SSL_TLS=True
USE_CREDENTIALS=True
VALIDATE_CERTS=True

# Domain (your app's public domain)
DOMAIN=localhost:8000

# DeepSeek AI (optional — mock fallback if not set)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
